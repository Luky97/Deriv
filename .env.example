# Copy this file to .env.local for local-only values.
# Never commit real Deriv API tokens or private credentials.

DERIV_APP_ID=your_deriv_app_id_here
DERIV_API_TOKEN=your_deriv_api_token_here

# Optional backend URL if you later connect a scanner/backend service.
VITE_API_BASE_URL=http://localhost:4000

# For GitHub Pages production builds, set this to your repository name:
# VITE_BASE_PATH=/REPOSITORY_NAME/
VITE_BASE_PATH=/
